# Supabase Configuration
VITE_SUPABASE_URL=https://qszfkwshuhmedmzufalh.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_key_here

# Environment
VITE_APP_ENV=development
VITE_SENTRY_DSN=

# Feature Flags
VITE_ENABLE_MOCK_DATA=false
VITE_FLAG_INVESTOR_READY_SECURITY=false
VITE_FLAG_TENANT_RBAC=false
VITE_FLAG_AUTOMATED_PROVISIONING=false
VITE_FLAG_STRICT_FINANCE_ACCESS=false

# Demo Mode
VITE_DEMO_MODE=false

# Storage
VITE_STORAGE_BUCKET=vehicles
VITE_STORAGE_URL=https://qszfkwshuhmedmzufalh.supabase.co/storage/v1

# Node scripts only (NO se expone al frontend)
SUPABASE_URL=https://qszfkwshuhmedmzufalh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_secret_key_here

# Edge Functions – Sentry (errores con tags tenant/module). Opcional.
# supabase secrets set SENTRY_DSN=https://...@ingest.sentry.io/...
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Studio IA – Generador de descripciones (webhook n8n)
# La app llama a la Edge Function y esta reenvía el JSON a n8n (evita CORS).
# Opcional: en Supabase → Edge Functions → Secrets, N8N_DESCRIPTION_WEBHOOK_URL para otra URL.
# Por defecto la función usa: .../webhook-test/generador-de-descripciones

# Studio IA – Guiones para reels (Edge Function + OpenAI)
# OPENAI_API_KEY=sk-...

# Studio IA – Chat y generación con Anthropic (Edge Functions ai-chat, ai-generate)
# Configurar en Supabase: Project Settings → Edge Functions → Secrets
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# También se usa en vehicle-valuation para refinar precio con IA (opcional)

# Marketplaces (opcional): URL base de la API de Chile Autos si difiere del default.
# Configurar en Supabase Edge Functions → Secrets si Chile Autos te indica otra URL.
# CHILEAUTOS_API_URL=https://api.s.core.csnglobal.net

# Lookup de patente por scraper externo (Autofact + Playwright)
# Despliega el servicio en services/autofact-scraper y configura estos secrets en Supabase:
# AUTOFACT_SCRAPER_URL=https://tu-servicio/lookup-patente
# AUTOFACT_SCRAPER_TOKEN=change-this-token
#
# API de GetAPI para lookup de patente (chile.getapi.cl). Configúrala como secret en Supabase:
# GETAPI_API_KEY=tu_api_key_de_getapi
# Proxy para ChileAutos/Yapo (lookup por patente y tasación). En Supabase: Edge Functions → Secrets, nombre exacto: SCRAPER_API_KEY
# SCRAPER_API_KEY=tu_api_key_de_scraperapi

# WhatsApp Business (Meta Cloud API) - Mensajería oficial
# Usado por:
# - supabase/functions/whatsapp-send (env: META_ACCESS_TOKEN, META_PHONE_NUMBER_ID)
# - supabase/functions/meta-webhook (env: META_APP_SECRET, META_WEBHOOK_VERIFY_TOKEN)
# META_ACCESS_TOKEN=EAAG... (System User token)
# META_PHONE_NUMBER_ID=XXXXXXXXXXXX
# META_WABA_ID=YYYYYYYYYYYY
# META_APP_SECRET=tu_app_secret_de_meta
# META_WEBHOOK_VERIFY_TOKEN=un_token_aleatorio_para_verificar_webhook

# Edge Function lead-create — ingestión de leads desde n8n (POST con x-api-key)
# supabase secrets set LEAD_INGEST_API_KEY=tu_clave_larga_aleatoria
# URL: https://<PROJECT_REF>.supabase.co/functions/v1/lead-create

