# Supabase Configuration
VITE_SUPABASE_URL=https://qszfkwshuhmedmzufalh.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_key_here

# Environment
VITE_APP_ENV=development

# Feature Flags
VITE_ENABLE_MOCK_DATA=false

# Demo Mode
VITE_DEMO_MODE=false

# Storage
VITE_STORAGE_BUCKET=vehicles
VITE_STORAGE_URL=https://qszfkwshuhmedmzufalh.supabase.co/storage/v1

# Node scripts only (NO se expone al frontend)
SUPABASE_URL=https://qszfkwshuhmedmzufalh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_secret_key_here

# Studio IA – Generador de descripciones (webhook n8n)
# La app llama a la Edge Function y esta reenvía el JSON a n8n (evita CORS).
# Opcional: en Supabase → Edge Functions → Secrets, N8N_DESCRIPTION_WEBHOOK_URL para otra URL.
# Por defecto la función usa: .../webhook-test/generador-de-descripciones

# Studio IA – Guiones para reels (Edge Function + OpenAI)
# OPENAI_API_KEY=sk-...

# Studio IA – Chat y generación con Anthropic (Edge Functions ai-chat, ai-generate)
# Configurar en Supabase: Project Settings → Edge Functions → Secrets
# supabase secrets set ANTHROPIC_API_KEY=sk-ant-...

# Marketplaces (opcional): URL base de la API de Chile Autos si difiere del default.
# Configurar en Supabase Edge Functions → Secrets si Chile Autos te indica otra URL.
# CHILEAUTOS_API_URL=https://api.s.core.csnglobal.net

