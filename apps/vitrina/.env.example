# URL del proyecto Supabase (misma que la app interna)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Base de Edge Functions (opcional; por defecto: {SUPABASE_URL}/functions/v1)
# VITRINA_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1

