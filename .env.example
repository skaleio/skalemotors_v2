# ───────────────────────────────────────────────
# Frontend (Vite — prefixed with VITE_)
# ───────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ───────────────────────────────────────────────
# Serverless Functions (api/ directory)
# ───────────────────────────────────────────────

# Supabase service role key — bypasses RLS, used by API routes
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API key global (opcional) para /api/n8n-lead-ingest: si está definida y coincide con x-api-key,
# el body debe incluir branch_id. Para multi-cliente, omite esta variable y usa claves por sucursal
# en la tabla public.lead_ingest_keys (ver scripts/generate_lead_ingest_key.mjs).
N8N_LEAD_INGEST_API_KEY=
