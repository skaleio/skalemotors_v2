# Copia a `.env` en la raíz (junto a package.json). Duplicado de referencia con `env.example`.

# Supabase Configuration
VITE_SUPABASE_URL=https://qszfkwshuhmedmzufalh.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_key_here

# Environment
VITE_APP_ENV=development
VITE_SENTRY_DSN=

# Feature Flags (override global; por tenant → tabla `tenant_feature_flags`)
VITE_ENABLE_MOCK_DATA=false
VITE_FLAG_INVESTOR_READY_SECURITY=false
VITE_FLAG_TENANT_RBAC=false
VITE_FLAG_AUTOMATED_PROVISIONING=false
VITE_FLAG_STRICT_FINANCE_ACCESS=false

# Demo Mode
VITE_DEMO_MODE=false

# Storage
VITE_STORAGE_BUCKET=vehicles
VITE_STORAGE_URL=https://qszfkwshuhmedmzufalh.supabase.co/storage/v1

# Node scripts only (NO se expone al frontend)
SUPABASE_URL=https://qszfkwshuhmedmzufalh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_secret_key_here

# Edge Functions – Sentry (opcional)
# supabase secrets set SENTRY_DSN=https://...@ingest.sentry.io/...
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Studio IA, marketplaces, scrapers: ver `env.example` para el resto de variables comentadas.
