# ───────────────────────────────────────────────
# Frontend (Vite — prefixed with VITE_)
# ───────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# URL completa del POST de ingesta de leads (Vercel). Se muestra en Integraciones.
# Ejemplo: https://tu-proyecto.vercel.app/api/n8n-lead-ingest
VITE_N8N_LEAD_INGEST_URL=

# ───────────────────────────────────────────────
# Serverless Functions (api/ directory)
# ───────────────────────────────────────────────

# Supabase service role key — bypasses RLS, used by API routes
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API key global (opcional) para /api/n8n-lead-ingest: si está definida y coincide con x-api-key,
# el body debe incluir branch_id. Para multi-cliente, omite esta variable y usa claves por sucursal
# en la tabla public.lead_ingest_keys (crear desde la app: Integraciones → API n8n).
N8N_LEAD_INGEST_API_KEY=
