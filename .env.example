# Copia a `.env` en la raíz (junto a package.json).
# Las variables VITE_* se exponen al frontend (bundle de Vite).
# Las variables sin VITE_ son solo para scripts Node/servidor.

# ============================================================
# VERCEL — OBLIGATORIAS PARA PRODUCCIÓN
# ============================================================
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_<your_anon_key>
VITE_APP_ENV=production
VITE_SENTRY_DSN=https://...@ingest.sentry.io/<project-id>

# ============================================================
# VERCEL — OPCIONALES
# ============================================================
# Feature Flags (override global; por tenant → tabla `tenant_feature_flags`)
VITE_ENABLE_MOCK_DATA=false
VITE_FLAG_INVESTOR_READY_SECURITY=false
VITE_FLAG_TENANT_RBAC=false
VITE_FLAG_AUTOMATED_PROVISIONING=false
VITE_FLAG_STRICT_FINANCE_ACCESS=false

VITE_DEMO_MODE=false
VITE_STORAGE_BUCKET=vehicles
VITE_STORAGE_URL=https://<project-ref>.supabase.co/storage/v1

# ============================================================
# SCRIPTS NODE (no se expone al frontend)
# ============================================================
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<your_service_role_key>

# ============================================================
# SUPABASE SECRETS — configurar con:
#   npx supabase secrets set KEY=VALUE
# ============================================================

# Webhooks / ingesta de leads desde sistemas externos (OBLIGATORIO post-deploy)
# LEAD_INGEST_API_KEY=<random-uuid-or-long-secret>
# LEAD_STATE_API_KEY=<random-uuid-or-long-secret>
# PENDING_TASK_API_KEY=<random-uuid-or-long-secret>

# IA (necesario para que ai-chat y support-chat funcionen)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# WhatsApp / Meta
# META_APP_SECRET=<meta_app_secret>
# META_WEBHOOK_VERIFY_TOKEN=<token_personalizado>
# META_ACCESS_TOKEN=<permanent_meta_token>
# META_PHONE_NUMBER_ID=<phone_number_id>

# Sentry (Edge Functions)
# SENTRY_DSN=https://...@ingest.sentry.io/...
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
