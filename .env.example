# ───────────────────────────────────────────────
# Frontend (Vite — prefixed with VITE_)
# ───────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Environment
VITE_APP_ENV=development

# URL canónica del frontend (producción). Enlaces de recuperación de contraseña (…/reset-password).
# Debe coincidir con Site URL / Redirect URLs en Supabase Auth.
# Ejemplo: https://app.tudominio.com
VITE_PUBLIC_APP_URL=

# URL completa del POST de ingesta de leads (Vercel). Se muestra en Integraciones → API n8n.
# Ejemplo: https://tu-proyecto.vercel.app/api/n8n-lead-ingest
VITE_N8N_LEAD_INGEST_URL=

# Sentry (frontend): DSN del proyecto → Client Keys en Sentry.
# https://supabase.com/docs/guides/telemetry/sentry-monitoring
VITE_SENTRY_DSN=

# Feature Flags
VITE_ENABLE_MOCK_DATA=false
# Producción segura: true activa MFA obligatorio (admin/gerente/jefe_jefe) + enroll TOTP
VITE_FLAG_INVESTOR_READY_SECURITY=false
# Alternativa granular (OR con VITE_FLAG_INVESTOR_READY_SECURITY)
VITE_MFA_GATE_ENABLED=false
VITE_MFA_ENROLLMENT_MANDATORY=false
VITE_FLAG_TENANT_RBAC=false
VITE_FLAG_AUTOMATED_PROVISIONING=false
VITE_FLAG_STRICT_FINANCE_ACCESS=false

# Demo Mode
VITE_DEMO_MODE=false

# Dev: login rápido (timeouts cortos, cache 24h, sin MFA en login). false = igual que prod en local.
# VITE_AUTH_FAST_DEV=false

# Cierre de sesión por inactividad (ms). Por defecto 30 min. En dev podés subirlo: 86400000
# VITE_SESSION_INACTIVITY_MS=1800000

# Storage
VITE_STORAGE_BUCKET=vehicles
VITE_STORAGE_URL=https://your-project.supabase.co/storage/v1

# Google Calendar (OAuth en el cliente)
# VITE_GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# VITE_GOOGLE_API_KEY=...

# ───────────────────────────────────────────────
# Serverless / scripts (api/, Node) — no exponer al bundle Vite
# ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Lead ingest (Vercel api/n8n-lead-ingest): orígenes CORS permitidos (comma-separated).
# En producción NO usar N8N_LEAD_INGEST_API_KEY; usar lead_ingest_keys por branch.
# LEAD_INGEST_ALLOWED_ORIGINS=https://n8n.tudominio.com

# Supabase Edge Functions: CORS lockdown (comma-separated frontend origins)
# ALLOWED_ORIGINS=https://app.tudominio.com
# LEGACY_BYPASS_EMAILS=hessen@test.io

# Logout automático tras inactividad (ms). Default 30 min si no se define.
# VITE_SESSION_INACTIVITY_MS=1800000

# ChileAutos scrape (api/chileautos-scrape.ts) — obligatorio en producción
# CHILEAUTOS_SCRAPE_API_KEY=

# Plantilla completa producción: .env.production.example

# App vitrina pública (apps/vitrina) — copiar también a apps/vitrina/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_DEFAULT_HOST=tu-tenant.skalemotors.cl

# API key global (opcional) para /api/n8n-lead-ingest: si está definida y coincide con x-api-key,
# el body debe incluir branch_id. Para multi-cliente, omite esta variable y usa claves por sucursal
# en public.lead_ingest_keys (Integraciones → API n8n).
N8N_LEAD_INGEST_API_KEY=

# ───────────────────────────────────────────────
# Supabase Edge Functions → Secrets (no van en .env del frontend)
# ───────────────────────────────────────────────
# Sentry en funciones: supabase secrets set SENTRY_DSN=...
# supabase secrets set SENTRY_ENVIRONMENT=production
# supabase secrets set SENTRY_TRACES_SAMPLE_RATE=0.1
#
# Studio IA / n8n (opcional en Secrets): N8N_DESCRIPTION_WEBHOOK_URL
# Zernio (redes sociales — solo Supabase Secrets, no en cliente):
# ZERNIO_API_KEY=sk_...
# OpenAI: OPENAI_API_KEY=sk-...
# Anthropic: ANTHROPIC_API_KEY=sk-ant-...
#
# Marketplaces (opcional): CHILEAUTOS_API_URL=https://api.s.core.csnglobal.net
#
# Autofact scraper: AUTOFACT_SCRAPER_URL, AUTOFACT_SCRAPER_TOKEN
# GetAPI patente: GETAPI_API_KEY
# Proxy scraper: SCRAPER_API_KEY
#
# WhatsApp / Meta (webhook global de la app Skale; tokens por sucursal vía Integraciones):
# META_APP_SECRET, META_WEBHOOK_VERIFY_TOKEN
# Solo legacy / piloto único (opcional): WHATSAPP_LEGACY_GLOBAL_FALLBACK=true + META_ACCESS_TOKEN + META_PHONE_NUMBER_ID
#
# YCloud (URL pública del webhook; API keys por tenant en BD vía Integraciones):
# YCLOUD_WEBHOOK_PUBLIC_URL=https://<proyecto>.supabase.co/functions/v1/ycloud-webhook
#
# Ingesta lead-create (Edge): supabase secrets set LEAD_INGEST_API_KEY=...
#
# Vitrina — dominios (Edge vitrina-domain; solo servidor, nunca en Vite):
# supabase secrets set VERCEL_API_TOKEN=...
# supabase secrets set VERCEL_PROJECT_ID_VITRINA=prj_...
# supabase secrets set VERCEL_TEAM_ID=team_...   # opcional si el proyecto está en un team
# supabase secrets set VITRINA_BASE_DOMAIN=skalemotors.cl

# ───────────────────────────────────────────────
# Claude Code → MCP n8n (solo entorno local del desarrollador)
# ───────────────────────────────────────────────
# JWT del MCP server expuesto por n8n (Settings → MCP Server → Generate API key).
# Se consume por expansión ${N8N_MCP_TOKEN} en .mcp.json. Export en tu shell antes
# de lanzar Claude Code. NUNCA commitear el valor.
#   export N8N_MCP_TOKEN=eyJhbGciOi...
N8N_MCP_TOKEN=
