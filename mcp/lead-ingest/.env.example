# Endpoint de ingesta (mismo que usa n8n). Reemplazar por el dominio real de prod.
SKALE_INGEST_URL=https://app.skalemotors.com/api/n8n-lead-ingest

# Clave generada con scripts/generate_lead_ingest_key.mjs (scopeada a una sucursal).
# NUNCA commitear el valor real.
SKALE_INGEST_API_KEY=

# Opcional: si la key ya está scopeada a la sucursal, dejar vacío y el server la resuelve.
# SKALE_BRANCH_ID=
